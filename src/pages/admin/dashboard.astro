---
// src/pages/admin/dashboard.astro
// Full CRUD admin panel for radar alerts and products

// Auth check
const cookie = Astro.cookies.get('admin_auth');
if (cookie?.value !== 'true') {
  return Astro.redirect('/admin');
}

import { getAdminClient } from '../../lib/supabase';
import type { RadarAlert, Product } from '../../lib/supabase';

const db = getAdminClient();

let message = '';
let messageType: 'success' | 'error' = 'success';

// ── HANDLE FORM ACTIONS ──────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  // LOGOUT
  if (action === 'logout') {
    Astro.cookies.delete('admin_auth', { path: '/admin' });
    return Astro.redirect('/admin');
  }

  // CREATE ALERT
  if (action === 'create_alert') {
    const { error } = await db.from('radar_alerts').insert({
      category:         form.get('category'),
      type:             form.get('type'),
      status:           form.get('status') ?? 'draft',
      emoji:            form.get('emoji') || '📢',
      tag_label:        form.get('tag_label'),
      date_label:       form.get('date_label') || 'Today',
      title:            form.get('title'),
      body:             form.get('body'),
      info_box_variant: form.get('info_box_variant') || null,
      info_box_html:    form.get('info_box_html') || null,
      official_link:    form.get('official_link') || null,
      official_label:   form.get('official_label') || null,
      share_key:        form.get('share_key'),
      warn_btn:         form.get('warn_btn') === 'true',
      sort_order:       parseInt(form.get('sort_order') as string) || 100,
    });
    message = error ? `Error: ${error.message}` : '✅ Alert created successfully!';
    messageType = error ? 'error' : 'success';
  }

  // UPDATE ALERT STATUS
  if (action === 'update_alert_status') {
    const id     = form.get('id') as string;
    const status = form.get('status') as string;
    const { error } = await db.from('radar_alerts').update({ status }).eq('id', id);
    message = error ? `Error: ${error.message}` : `✅ Alert ${status}`;
    messageType = error ? 'error' : 'success';
  }

  // DELETE ALERT
  if (action === 'delete_alert') {
    const id = form.get('id') as string;
    const { error } = await db.from('radar_alerts').delete().eq('id', id);
    message = error ? `Error: ${error.message}` : '🗑️ Alert deleted';
    messageType = error ? 'error' : 'success';
  }

  // TOGGLE PRODUCT ACTIVE
  if (action === 'toggle_product') {
    const id     = form.get('id') as string;
    const active = form.get('active') === 'true';
    const { error } = await db.from('products').update({ active }).eq('id', id);
    message = error ? `Error: ${error.message}` : `✅ Product ${active ? 'activated' : 'deactivated'}`;
    messageType = error ? 'error' : 'success';
  }
}

// ── FETCH DATA ───────────────────────────────────────────────
const { data: alertsRaw } = await db.from('radar_alerts').select('*').order('sort_order');
const { data: productsRaw } = await db.from('products').select('*').order('sort_order');

const allAlerts  = (alertsRaw  ?? []) as RadarAlert[];
const allProducts = (productsRaw ?? []) as Product[];

const categoryColors: Record<string, string> = {
  sassa: '#60a5fa', gov: '#24a064', sars: '#f5c842', scam: '#f87171'
};
const statusColors: Record<string, string> = {
  active: '#24a064', draft: '#a09a8e', archived: '#f87171'
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | SA Life Hub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #0e0e0e; --black2: #161616; --gold: #f5c842;
      --green: #24a064; --white: #f5f0e8; --muted: #a09a8e;
      --card: #1a1a1a; --border: #2a2a2a; --red: #f87171;
      --font-head: 'Syne', sans-serif; --font-body: 'DM Sans', sans-serif;
      --r: 10px;
    }
    body { background: var(--black2); color: var(--white); font-family: var(--font-body); min-height: 100vh; }

    /* TOP BAR */
    .topbar { background: var(--black); border-bottom: 1px solid var(--border); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar-logo { font-family: var(--font-head); font-weight: 800; font-size: 1rem; }
    .topbar-logo span { color: var(--gold); }
    .topbar-right { display: flex; align-items: center; gap: 10px; font-size: 0.78rem; color: var(--muted); }

    /* LAYOUT */
    .container { max-width: 900px; margin: 0 auto; padding: 24px 16px; }

    /* MESSAGE */
    .msg { padding: 12px 16px; border-radius: var(--r); font-size: 0.82rem; margin-bottom: 20px; }
    .msg.success { background: rgba(36,160,100,0.12); border: 1px solid rgba(36,160,100,0.3); color: var(--green); }
    .msg.error   { background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.3); color: var(--red); }

    /* SECTION */
    .section-title { font-family: var(--font-head); font-weight: 700; font-size: 1rem; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }

    /* CARD */
    .card { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 18px; margin-bottom: 10px; }

    /* STATS ROW */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 28px; }
    .stat { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 14px; text-align: center; }
    .stat-num   { font-family: var(--font-head); font-weight: 800; font-size: 1.5rem; color: var(--gold); }
    .stat-label { font-size: 0.68rem; color: var(--muted); margin-top: 2px; }

    /* TABLE */
    .alert-row { display: flex; align-items: flex-start; gap: 10px; padding: 12px 0; border-bottom: 1px solid var(--border); }
    .alert-row:last-child { border-bottom: none; }
    .alert-emoji { font-size: 1.3rem; flex-shrink: 0; width: 28px; text-align: center; margin-top: 2px; }
    .alert-info { flex: 1; min-width: 0; }
    .alert-title { font-size: 0.82rem; font-weight: 600; line-height: 1.3; margin-bottom: 4px; }
    .alert-meta  { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .badge { font-size: 0.62rem; font-weight: 700; padding: 2px 8px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; }
    .alert-actions { display: flex; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }

    /* FORMS */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } .stats { grid-template-columns: 2fr 2fr; } }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group.full { grid-column: 1 / -1; }
    label { font-size: 0.74rem; color: var(--muted); font-weight: 500; }
    input, select, textarea {
      background: var(--black2); border: 1px solid var(--border); border-radius: 7px;
      padding: 9px 12px; color: var(--white); font-size: 0.82rem;
      font-family: var(--font-body); outline: none; width: 100%;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--gold); }
    textarea { resize: vertical; min-height: 80px; }
    select option { background: var(--black2); }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 5px; padding: 7px 13px; border-radius: 6px; font-family: var(--font-head); font-weight: 700; font-size: 0.72rem; border: none; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn-gold    { background: var(--gold); color: var(--black); }
    .btn-outline { background: transparent; color: var(--white); border: 1px solid var(--border); }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
    .btn-green   { background: rgba(36,160,100,0.2); color: var(--green); border: 1px solid rgba(36,160,100,0.3); }
    .btn-red     { background: rgba(248,113,113,0.15); color: var(--red); border: 1px solid rgba(248,113,113,0.3); }
    .btn-sm      { padding: 5px 10px; font-size: 0.66rem; }

    /* COLLAPSIBLE */
    details.panel summary { cursor: pointer; list-style: none; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; font-family: var(--font-head); font-weight: 700; font-size: 0.9rem; }
    details.panel summary::-webkit-details-marker { display: none; }
    details.panel summary::after { content: '＋'; color: var(--gold); }
    details.panel[open] summary::after { content: '－'; }
    details.panel .panel-body { padding: 0 18px 18px; border-top: 1px solid var(--border); padding-top: 16px; }

    /* PRODUCT ROW */
    .product-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); }
    .product-row:last-child { border-bottom: none; }
    .product-emoji { font-size: 1.4rem; }
    .product-info { flex: 1; }
    .product-name { font-size: 0.85rem; font-weight: 600; }
    .product-price { font-size: 0.75rem; color: var(--gold); font-family: var(--font-head); font-weight: 700; }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-logo">SA <span>Life</span> Hub <span style="color:var(--muted);font-family:var(--font-body);font-weight:400;font-size:0.75rem;">/ Admin</span></div>
  <div class="topbar-right">
    <a href="/" style="color:var(--muted);text-decoration:none;">← Site</a>
    <form method="POST" style="margin:0;">
      <input type="hidden" name="_action" value="logout" />
      <button class="btn btn-outline btn-sm" type="submit">Logout</button>
    </form>
  </div>
</div>

<div class="container">

  {message && <div class={`msg ${messageType}`}>{message}</div>}

  <!-- STATS -->
  <div class="stats">
    <div class="stat">
      <div class="stat-num">{allAlerts.filter(a => a.status === 'active').length}</div>
      <div class="stat-label">Active Alerts</div>
    </div>
    <div class="stat">
      <div class="stat-num">{allAlerts.filter(a => a.category === 'scam').length}</div>
      <div class="stat-label">Scam Alerts</div>
    </div>
    <div class="stat">
      <div class="stat-num">{allAlerts.filter(a => a.status === 'draft').length}</div>
      <div class="stat-label">Drafts</div>
    </div>
    <div class="stat">
      <div class="stat-num">{allProducts.filter(p => p.active).length}</div>
      <div class="stat-label">Active Products</div>
    </div>
  </div>

  <!-- ── RADAR ALERTS ── -->
  <div class="section-title">⚠️ Radar Alerts <span style="color:var(--muted);font-weight:400;font-size:0.78rem;">({allAlerts.length} total)</span></div>

  <!-- CREATE NEW ALERT -->
  <details class="panel card" style="padding:0;margin-bottom:14px;">
    <summary>➕ Create New Alert</summary>
    <div class="panel-body">
      <form method="POST">
        <input type="hidden" name="_action" value="create_alert" />
        <div class="form-grid">
          <div class="form-group">
            <label>Category *</label>
            <select name="category" required>
              <option value="sassa">SASSA</option>
              <option value="gov">Gov Update</option>
              <option value="sars">SARS</option>
              <option value="scam">Scam Radar</option>
            </select>
          </div>
          <div class="form-group">
            <label>Type *</label>
            <select name="type" required>
              <option value="update">Update</option>
              <option value="scam">Scam</option>
              <option value="fake">Fake News</option>
            </select>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select name="status">
              <option value="active">Active (live now)</option>
              <option value="draft">Draft (hidden)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Emoji</label>
            <input type="text" name="emoji" placeholder="📢" maxlength="4" />
          </div>
          <div class="form-group">
            <label>Tag Label * (e.g. "SASSA" or "⚠️ SCAM ALERT")</label>
            <input type="text" name="tag_label" required placeholder="SASSA" />
          </div>
          <div class="form-group">
            <label>Date Label (e.g. "April 2025", "Active Now")</label>
            <input type="text" name="date_label" placeholder="Today" />
          </div>
          <div class="form-group full">
            <label>Title *</label>
            <input type="text" name="title" required placeholder="Alert headline..." />
          </div>
          <div class="form-group full">
            <label>Body * (HTML allowed)</label>
            <textarea name="body" required placeholder="Main alert content. You can use &lt;strong&gt; tags."></textarea>
          </div>
          <div class="form-group">
            <label>Info Box Variant</label>
            <select name="info_box_variant">
              <option value="">None</option>
              <option value="blue">Blue</option>
              <option value="gold">Gold</option>
              <option value="green">Green</option>
              <option value="dark">Dark</option>
              <option value="red">Red</option>
            </select>
          </div>
          <div class="form-group">
            <label>Share Key * (matches BaseLayout shareMessages)</label>
            <input type="text" name="share_key" required placeholder="sassa-dates" />
          </div>
          <div class="form-group full">
            <label>Info Box HTML (optional)</label>
            <textarea name="info_box_html" placeholder="📅 Pay window: 25 March..."></textarea>
          </div>
          <div class="form-group">
            <label>Official Link (optional)</label>
            <input type="url" name="official_link" placeholder="https://srd.sassa.gov.za" />
          </div>
          <div class="form-group">
            <label>Official Link Label</label>
            <input type="text" name="official_label" placeholder="Check My Status →" />
          </div>
          <div class="form-group">
            <label>Sort Order (lower = first)</label>
            <input type="number" name="sort_order" value="100" min="1" />
          </div>
          <div class="form-group">
            <label>Show Warn Button (red) instead of Share</label>
            <select name="warn_btn">
              <option value="false">No — standard share button</option>
              <option value="true">Yes — red warn button</option>
            </select>
          </div>
        </div>
        <button class="btn btn-gold" type="submit" style="margin-top:16px;padding:10px 20px;">
          ➕ Create Alert
        </button>
      </form>
    </div>
  </details>

  <!-- ALERT LIST -->
  <div class="card">
    {allAlerts.length === 0 && <div style="text-align:center;padding:20px;color:var(--muted);font-size:0.82rem;">No alerts yet. Create one above.</div>}
    {allAlerts.map((alert: RadarAlert) => (
      <div class="alert-row">
        <div class="alert-emoji">{alert.emoji}</div>
        <div class="alert-info">
          <div class="alert-title">{alert.title}</div>
          <div class="alert-meta">
            <span class="badge" style={`background:${categoryColors[alert.category]}22;color:${categoryColors[alert.category]};border:1px solid ${categoryColors[alert.category]}44;`}>{alert.category}</span>
            <span class="badge" style={`background:${statusColors[alert.status]}22;color:${statusColors[alert.status]};border:1px solid ${statusColors[alert.status]}44;`}>{alert.status}</span>
            <span style="font-size:0.68rem;color:var(--muted);">{alert.date_label}</span>
          </div>
        </div>
        <div class="alert-actions">
          {alert.status !== 'active' && (
            <form method="POST" style="margin:0;">
              <input type="hidden" name="_action" value="update_alert_status" />
              <input type="hidden" name="id" value={alert.id} />
              <input type="hidden" name="status" value="active" />
              <button class="btn btn-green btn-sm" type="submit">Publish</button>
            </form>
          )}
          {alert.status === 'active' && (
            <form method="POST" style="margin:0;">
              <input type="hidden" name="_action" value="update_alert_status" />
              <input type="hidden" name="id" value={alert.id} />
              <input type="hidden" name="status" value="archived" />
              <button class="btn btn-outline btn-sm" type="submit">Archive</button>
            </form>
          )}
          <form method="POST" style="margin:0;" onsubmit="return confirm('Delete this alert permanently?')">
            <input type="hidden" name="_action" value="delete_alert" />
            <input type="hidden" name="id" value={alert.id} />
            <button class="btn btn-red btn-sm" type="submit">Delete</button>
          </form>
        </div>
      </div>
    ))}
  </div>

  <!-- ── PRODUCTS ── -->
  <div class="section-title" style="margin-top:32px;">📦 Products</div>
  <div class="card">
    {allProducts.map((p: Product) => (
      <div class="product-row">
        <div class="product-emoji">{p.emoji}</div>
        <div class="product-info">
          <div class="product-name">{p.name}</div>
          <div class="product-price">R{p.price_rands} · <span style="color:var(--muted);font-family:var(--font-body);font-weight:400;">{p.paystack_slug}</span></div>
        </div>
        <div style="display:flex;gap:6px;align-items:center;">
          <span class="badge" style={`background:${p.active ? 'rgba(36,160,100,0.15)' : 'rgba(160,154,142,0.1)'};color:${p.active ? 'var(--green)' : 'var(--muted)'};border:1px solid ${p.active ? 'rgba(36,160,100,0.3)' : 'var(--border)'};`}>
            {p.active ? 'Active' : 'Hidden'}
          </span>
          <form method="POST" style="margin:0;">
            <input type="hidden" name="_action" value="toggle_product" />
            <input type="hidden" name="id" value={p.id} />
            <input type="hidden" name="active" value={String(!p.active)} />
            <button class={`btn btn-sm ${p.active ? 'btn-outline' : 'btn-green'}`} type="submit">
              {p.active ? 'Hide' : 'Show'}
            </button>
          </form>
        </div>
      </div>
    ))}
  </div>

  <div style="margin-top:20px;padding:14px;background:var(--card);border:1px solid var(--border);border-radius:var(--r);font-size:0.76rem;color:var(--muted);line-height:1.6;">
    💡 <strong style="color:var(--white);">To add a new product:</strong> Go to your Supabase dashboard → Table Editor → products → Insert row. Products added there will appear here automatically.
  </div>

</div>
</body>
</html>
