---
// src/pages/admin/index.astro
// Simple password-protected admin panel entry point

// Redirect to dashboard if already authenticated via cookie
const cookie = Astro.cookies.get('admin_auth');
if (cookie?.value === 'true') {
  return Astro.redirect('/admin/dashboard');
}

let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password') as string;
  const adminPassword = import.meta.env.ADMIN_PASSWORD ?? 'admin123';

  if (password === adminPassword) {
    Astro.cookies.set('admin_auth', 'true', {
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 8, // 8 hours
      path: '/admin',
    });
    return Astro.redirect('/admin/dashboard');
  } else {
    error = 'Incorrect password. Try again.';
  }
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | SA Life Hub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0e0e0e; color: #f5f0e8;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      padding: 20px;
    }
    .login-card {
      background: #1a1a1a; border: 1px solid #2a2a2a;
      border-top: 3px solid #f5c842;
      border-radius: 16px; padding: 32px 28px;
      width: 100%; max-width: 360px;
    }
    .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem; margin-bottom: 6px; }
    .logo span { color: #f5c842; }
    .subtitle { font-size: 0.8rem; color: #a09a8e; margin-bottom: 28px; }
    label { display: block; font-size: 0.78rem; color: #a09a8e; margin-bottom: 6px; font-weight: 500; }
    input[type="password"] {
      width: 100%; background: #0e0e0e; border: 1px solid #2a2a2a;
      border-radius: 8px; padding: 12px 14px; color: #f5f0e8;
      font-size: 0.9rem; outline: none; margin-bottom: 16px;
      font-family: 'DM Sans', sans-serif;
    }
    input[type="password"]:focus { border-color: #f5c842; }
    button {
      width: 100%; background: #f5c842; color: #0e0e0e;
      border: none; border-radius: 8px; padding: 13px;
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem;
      cursor: pointer; transition: background 0.15s;
    }
    button:hover { background: #f7d060; }
    .error { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.3); border-radius: 8px; padding: 10px 14px; font-size: 0.8rem; color: #f87171; margin-bottom: 16px; }
    .back { text-align: center; margin-top: 16px; }
    .back a { font-size: 0.75rem; color: #a09a8e; text-decoration: none; }
    .back a:hover { color: #f5c842; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo">SA <span>Life</span> Hub</div>
    <div class="subtitle">Admin Panel — RealMaxG only</div>
    {error && <div class="error">❌ {error}</div>}
    <form method="POST">
      <label for="password">Admin Password</label>
      <input type="password" id="password" name="password" placeholder="Enter password" required autofocus />
      <button type="submit">🔐 Sign In</button>
    </form>
    <div class="back"><a href="/">← Back to site</a></div>
  </div>
</body>
</html>
