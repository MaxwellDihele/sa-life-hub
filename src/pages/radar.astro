---
// src/pages/radar.astro
// Fetches all active radar alerts from Supabase at request time
import BaseLayout from '../layouts/BaseLayout.astro';
import { getActiveAlerts } from '../lib/supabase';
import type { RadarAlert } from '../lib/supabase';

const alerts = await getActiveAlerts();

const sassaAlerts = alerts.filter(a => a.category === 'sassa');
const govAlerts   = alerts.filter(a => a.category === 'gov');
const sarsAlerts  = alerts.filter(a => a.category === 'sars');
const scamAlerts  = alerts.filter(a => a.category === 'scam');

// Color maps for tag + info box
const tagColors: Record<string, string> = {
  sassa: 'rgba(96,165,250,0.12);color:#60a5fa;border-color:rgba(96,165,250,0.3)',
  gov:   'rgba(36,160,100,0.12);color:var(--green2);border-color:rgba(36,160,100,0.3)',
  sars:  'rgba(245,200,66,0.12);color:var(--gold);border-color:rgba(245,200,66,0.3)',
  scam:  '',
};

const infoBoxStyles: Record<string, string> = {
  blue:  'background:rgba(96,165,250,0.07);border:1px solid rgba(96,165,250,0.2)',
  gold:  'background:rgba(245,200,66,0.07);border:1px solid rgba(245,200,66,0.2)',
  green: 'background:rgba(36,160,100,0.07);border:1px solid rgba(36,160,100,0.2)',
  dark:  'background:var(--black2);border:1px solid var(--border)',
  red:   'background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2)',
};
---

<BaseLayout
  title="SA Updates & Scam Radar | SA Life Hub"
  description="SASSA grant updates, SARS tax dates, government news, and active scam alerts for South Africans. Stay protected and informed."
  activeNav="radar"
>
  <style is:global>
    .section-divider { display:flex; align-items:center; gap:8px; padding:18px 20px 4px; }
    .section-divider-bar { width:3px; height:18px; border-radius:2px; }
    .section-divider span { font-family:var(--font-head); font-weight:700; font-size:0.9rem; }
    .radar-info-box { border-radius:var(--radius-sm); padding:10px 12px; font-size:0.76rem; line-height:1.6; margin-bottom:10px; }
    .scam-card { border-left:3px solid #f87171 !important; border-color:rgba(248,113,113,0.25) !important; }
    .empty-state { text-align:center; padding:40px 20px; color:var(--muted); font-size:0.85rem; }
  </style>

  <div class="page-header">
    <a href="/" class="back-btn" aria-label="Back to home">←</a>
    <div class="page-header-text">
      <h2>⚠️ SA Updates &amp; Radar</h2>
      <p>Grants · Gov · SARS · Scam Alerts</p>
    </div>
  </div>

  <div class="section-hero red-tint" style="padding-bottom:16px;">
    <p style="font-size:0.76rem;color:var(--muted);margin-bottom:10px;">Tap a category to filter. Share any alert directly to WhatsApp.</p>
    <div class="pill-row" id="radar-pills">
      <div class="pill active" data-filter="all">All</div>
      <div class="pill" data-filter="sassa">SASSA</div>
      <div class="pill" data-filter="gov">Gov Updates</div>
      <div class="pill" data-filter="sars">SARS</div>
      <div class="pill" data-filter="scam">⚠️ Scam Radar</div>
    </div>
  </div>

  {/* ── SASSA ── */}
  {sassaAlerts.length > 0 && (
    <div class="section-divider radar-section-header" data-section="sassa">
      <div class="section-divider-bar" style="background:#60a5fa;"></div>
      <span style="color:#60a5fa;">SASSA Grant Updates</span>
    </div>
  )}
  <div class="service-list" style="padding-top:0;">
    {sassaAlerts.map((alert: RadarAlert) => (
      <div class="trend-card radar-item" data-cat="sassa" style="flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:flex-start;gap:12px;">
          <div class="trend-emoji">{alert.emoji}</div>
          <div class="trend-body" style="flex:1;">
            <div class="trend-meta">
              <span class="trend-tag" style={`background:${tagColors.sassa}`}>{alert.tag_label}</span>
              <span>{alert.date_label}</span>
            </div>
            <h3>{alert.title}</h3>
            <p set:html={alert.body} />
            {alert.info_box_html && alert.info_box_variant && (
              <div class="radar-info-box" style={infoBoxStyles[alert.info_box_variant]} set:html={alert.info_box_html} />
            )}
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              {alert.official_link && (
                <a class="btn btn-outline" style="font-size:0.72rem;padding:8px 12px;" href={alert.official_link} target="_blank" rel="noopener">{alert.official_label}</a>
              )}
              <button class="btn btn-wa" style="font-size:0.72rem;padding:8px 12px;" data-wa-key={alert.share_key}>💬 Share Update</button>
            </div>
          </div>
        </div>
      </div>
    ))}
    {sassaAlerts.length === 0 && <div class="empty-state">No SASSA alerts at this time.</div>}
  </div>

  {/* ── GOV UPDATES ── */}
  {govAlerts.length > 0 && (
    <div class="section-divider radar-section-header" data-section="gov">
      <div class="section-divider-bar" style="background:var(--green2);"></div>
      <span style="color:var(--green2);">Government Updates</span>
    </div>
  )}
  <div class="service-list" style="padding-top:0;">
    {govAlerts.map((alert: RadarAlert) => (
      <div class="trend-card radar-item" data-cat="gov" style="flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:flex-start;gap:12px;">
          <div class="trend-emoji">{alert.emoji}</div>
          <div class="trend-body" style="flex:1;">
            <div class="trend-meta">
              <span class="trend-tag" style={`background:${tagColors.gov}`}>{alert.tag_label}</span>
              <span>{alert.date_label}</span>
            </div>
            <h3>{alert.title}</h3>
            <p set:html={alert.body} />
            {alert.info_box_html && alert.info_box_variant && (
              <div class="radar-info-box" style={infoBoxStyles[alert.info_box_variant]} set:html={alert.info_box_html} />
            )}
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              {alert.official_link && (
                <a class="btn btn-outline" style="font-size:0.72rem;padding:8px 12px;" href={alert.official_link} target="_blank" rel="noopener">{alert.official_label}</a>
              )}
              <button class="btn btn-wa" style="font-size:0.72rem;padding:8px 12px;" data-wa-key={alert.share_key}>💬 Share</button>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* ── SARS ── */}
  {sarsAlerts.length > 0 && (
    <div class="section-divider radar-section-header" data-section="sars">
      <div class="section-divider-bar" style="background:var(--gold);"></div>
      <span style="color:var(--gold);">SARS Tax Updates</span>
    </div>
  )}
  <div class="service-list" style="padding-top:0;">
    {sarsAlerts.map((alert: RadarAlert) => (
      <div class="trend-card radar-item" data-cat="sars" style="flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:flex-start;gap:12px;">
          <div class="trend-emoji">{alert.emoji}</div>
          <div class="trend-body" style="flex:1;">
            <div class="trend-meta">
              <span class="trend-tag" style={`background:${tagColors.sars}`}>{alert.tag_label}</span>
              <span>{alert.date_label}</span>
            </div>
            <h3>{alert.title}</h3>
            <p set:html={alert.body} />
            {alert.info_box_html && alert.info_box_variant && (
              <div class="radar-info-box" style={infoBoxStyles[alert.info_box_variant]} set:html={alert.info_box_html} />
            )}
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              {alert.official_link && (
                <a class="btn btn-outline" style="font-size:0.72rem;padding:8px 12px;" href={alert.official_link} target="_blank" rel="noopener">{alert.official_label}</a>
              )}
              <button class="btn btn-wa" style="font-size:0.72rem;padding:8px 12px;" data-wa-key={alert.share_key}>💬 Share</button>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* ── SCAM RADAR ── */}
  {scamAlerts.length > 0 && (
    <>
      <div class="section-divider radar-section-header" data-section="scam">
        <div class="section-divider-bar" style="background:#f87171;"></div>
        <span style="color:#f87171;">⚠️ Scam Radar — Fake News Alert</span>
      </div>
      <p style="font-size:0.75rem;color:var(--muted);padding:0 20px 10px;" class="radar-section-header">
        Share these to protect your community from scams circulating right now.
      </p>
    </>
  )}
  <div class="service-list" style="padding-top:0;">
    {scamAlerts.map((alert: RadarAlert) => (
      <div class="trend-card radar-item scam-card" data-cat="scam" style="flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:flex-start;gap:12px;">
          <div class="trend-emoji">{alert.emoji}</div>
          <div class="trend-body" style="flex:1;">
            <div class="trend-meta"><span class="trend-tag">{alert.tag_label}</span><span>{alert.date_label}</span></div>
            <h3>{alert.title}</h3>
            <p set:html={alert.body} />
            {alert.info_box_html && alert.info_box_variant && (
              <div class="radar-info-box" style={infoBoxStyles[alert.info_box_variant]} set:html={alert.info_box_html} />
            )}
            <button
              class="btn btn-wa"
              style={`font-size:0.72rem;padding:8px 12px;${alert.warn_btn ? 'background:#f87171;color:#fff;' : ''}`}
              data-wa-key={alert.share_key}
            >
              {alert.warn_btn ? '⚠️ Warn Your Community' : '💬 Share'}
            </button>
          </div>
        </div>
      </div>
    ))}

    {/* Report CTA — always shown */}
    <div style="background:rgba(248,113,113,0.06);border:1px solid rgba(248,113,113,0.2);border-radius:var(--radius);padding:18px;text-align:center;margin-top:4px;">
      <div style="font-size:1.4rem;margin-bottom:8px;">🛡️</div>
      <div style="font-family:var(--font-head);font-weight:700;font-size:0.9rem;margin-bottom:6px;">Spotted a Scam or Fake News?</div>
      <p style="font-size:0.75rem;color:var(--muted);line-height:1.55;margin-bottom:14px;">Share this page with your community. Every share could protect someone from losing their money.</p>
      <button class="btn btn-wa" style="width:100%;justify-content:center;" data-wa-key="scam-radar">💬 Share Scam Radar Page</button>
    </div>
  </div>

  <div class="bottom-spacer"></div>
</BaseLayout>

<script>
  // Category pill filter
  const pills = document.querySelectorAll('#radar-pills .pill');
  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.getAttribute('data-filter');
      document.querySelectorAll('.radar-item').forEach((card: Element) => {
        (card as HTMLElement).style.display =
          (filter === 'all' || card.getAttribute('data-cat') === filter) ? '' : 'none';
      });
      document.querySelectorAll('.radar-section-header').forEach((el: Element) => {
        (el as HTMLElement).style.display = filter === 'all' ? '' : 'none';
      });
    });
  });
</script>
