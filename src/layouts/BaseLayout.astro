---
// src/layouts/BaseLayout.astro
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  activeNav?: string; // 'home' | 'gov' | 'earn' | 'store' | 'radar'
}

const {
  title = 'SA Life Hub | Earn. Access. Stay Informed. 🇿🇦',
  description = 'SA Life Hub — South Africa\'s trusted digital hub for earning opportunities, government assistance, trending updates, and digital products. Built by RealMaxG.',
  activeNav = 'home',
} = Astro.props;

// Set PUBLIC_PAYSTACK_KEY in your .env file
const paystackKey = import.meta.env.PUBLIC_PAYSTACK_KEY ?? 'pk_live_REPLACE_WITH_YOUR_KEY';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="SASSA, NSFAS, UIF, South Africa jobs, side hustle SA, earn online South Africa, CV templates SA" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style is:global>
    /* ── DESIGN TOKENS ── */
    :root {
      --black:    #0e0e0e;
      --black2:   #161616;
      --gold:     #f5c842;
      --gold-dim: #c9a22a;
      --green:    #1e7d4f;
      --green2:   #24a064;
      --white:    #f5f0e8;
      --muted:    #a09a8e;
      --card-bg:  #1a1a1a;
      --border:   #2a2a2a;
      --red:      #e03c3c;
      --font-head: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --radius:    14px;
      --radius-sm: 8px;
      --shadow:    0 4px 24px rgba(0,0,0,0.45);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--font-body);
      max-width: 420px;
      margin: 0 auto;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.4;
    }
    /* ── BUTTONS ── */
    .btn { display:inline-flex; align-items:center; gap:7px; padding:12px 20px; border-radius:var(--radius-sm); font-family:var(--font-head); font-weight:700; font-size:0.82rem; letter-spacing:0.02em; text-decoration:none; cursor:pointer; border:none; transition:all 0.18s ease; -webkit-tap-highlight-color:transparent; }
    .btn-gold  { background:var(--gold); color:var(--black); }
    .btn-gold:hover,.btn-gold:active  { background:#f7d060; transform:translateY(-1px); }
    .btn-outline { background:transparent; color:var(--white); border:1px solid var(--border); }
    .btn-outline:hover,.btn-outline:active { border-color:var(--gold); color:var(--gold); }
    .btn-green { background:var(--green); color:var(--white); }
    .btn-green:hover,.btn-green:active { background:var(--green2); transform:translateY(-1px); }
    .btn-wa { background:#25D366; color:#fff; }
    .btn-wa:hover { background:#20b858; transform:translateY(-1px); }
    /* ── SECTIONS ── */
    .section { padding:10px 20px 32px; }
    .section-label { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .section-label h2 { font-family:var(--font-head); font-weight:700; font-size:1.05rem; letter-spacing:-0.01em; }
    .section-label a { font-size:0.78rem; color:var(--gold); text-decoration:none; font-weight:500; }
    /* ── SERVICE CARDS ── */
    .service-list { padding:20px; display:flex; flex-direction:column; gap:12px; }
    .service-card { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); padding:18px; transition:all 0.18s; -webkit-tap-highlight-color:transparent; }
    .service-card:hover,.service-card:active { border-color:#60a5fa; background:#1e2030; }
    .service-card-header { display:flex; align-items:center; gap:12px; margin-bottom:8px; }
    .service-card h3 { font-family:var(--font-head); font-weight:700; font-size:0.92rem; }
    .service-card p { font-size:0.78rem; color:var(--muted); line-height:1.55; margin-bottom:12px; }
    .service-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
    .service-icon.blue  { background:rgba(96,165,250,0.15); }
    .service-icon.gold  { background:rgba(245,200,66,0.12); }
    .service-icon.green { background:rgba(30,125,79,0.2); }
    /* ── STEPS ── */
    .step-list { list-style:none; display:flex; flex-direction:column; gap:8px; margin-bottom:14px; }
    .step-list li { display:flex; align-items:flex-start; gap:10px; font-size:0.8rem; line-height:1.5; color:var(--white); }
    .step-num { width:20px; height:20px; min-width:20px; background:var(--gold); color:var(--black); border-radius:50%; font-size:0.65rem; font-weight:800; display:flex; align-items:center; justify-content:center; font-family:var(--font-head); margin-top:1px; }
    .step-num.blue  { background:#60a5fa; }
    .step-num.green { background:var(--green2); }
    /* ── TREND CARDS ── */
    .trend-card { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); padding:16px; margin-bottom:12px; display:flex; gap:14px; }
    .trend-emoji { font-size:1.8rem; line-height:1; flex-shrink:0; }
    .trend-body h3 { font-family:var(--font-head); font-weight:700; font-size:0.9rem; margin-bottom:5px; line-height:1.3; }
    .trend-body p  { font-size:0.76rem; color:var(--muted); line-height:1.55; margin-bottom:10px; }
    .trend-meta    { display:flex; align-items:center; gap:10px; font-size:0.7rem; color:var(--muted); margin-bottom:10px; }
    .trend-tag { background:rgba(248,113,113,0.1); color:#f87171; border:1px solid rgba(248,113,113,0.2); padding:2px 8px; border-radius:100px; font-size:0.65rem; font-weight:600; text-transform:uppercase; letter-spacing:0.04em; }
    /* ── SECTION HERO ── */
    .section-hero        { background:linear-gradient(180deg,rgba(96,165,250,0.08) 0%,transparent 100%); padding:24px 20px 20px; }
    .section-hero.gold-tint  { background:linear-gradient(180deg,rgba(245,200,66,0.08) 0%,transparent 100%); }
    .section-hero.green-tint { background:linear-gradient(180deg,rgba(30,125,79,0.10) 0%,transparent 100%); }
    .section-hero.red-tint   { background:linear-gradient(180deg,rgba(224,60,60,0.08) 0%,transparent 100%); }
    .section-hero h2 { font-family:var(--font-head); font-weight:800; font-size:1.5rem; letter-spacing:-0.02em; margin-bottom:6px; }
    .section-hero p  { font-size:0.82rem; color:var(--muted); line-height:1.55; }
    /* ── PILLS ── */
    .pill-row { display:flex; gap:8px; flex-wrap:wrap; margin-top:12px; }
    .pill { background:var(--card-bg); border:1px solid var(--border); font-size:0.7rem; padding:5px 12px; border-radius:100px; color:var(--white); cursor:pointer; }
    .pill.active,.pill:hover { background:var(--gold); color:var(--black); border-color:var(--gold); font-weight:600; }
    /* ── ALERT BANNER ── */
    .alert-banner { margin:0 20px 24px; background:rgba(245,200,66,0.08); border:1px solid rgba(245,200,66,0.25); border-left:3px solid var(--gold); border-radius:var(--radius-sm); padding:12px 14px; font-size:0.8rem; line-height:1.5; color:var(--white); }
    .alert-banner strong { color:var(--gold); font-weight:600; }
    /* ── WA CTA ── */
    .wa-cta { margin:0 20px 24px; background:linear-gradient(135deg,rgba(37,211,102,0.1) 0%,rgba(37,211,102,0.05) 100%); border:1px solid rgba(37,211,102,0.25); border-radius:var(--radius); padding:18px; text-align:center; }
    .wa-cta p { font-size:0.8rem; color:var(--muted); margin-bottom:12px; line-height:1.5; }
    .wa-cta strong { color:var(--white); display:block; font-family:var(--font-head); font-size:0.95rem; margin-bottom:5px; }
    /* ── STATS BAR ── */
    .stats-bar { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1px; background:var(--border); border-top:1px solid var(--border); border-bottom:1px solid var(--border); margin-bottom:28px; }
    .stat-item { background:var(--black2); padding:16px 12px; text-align:center; }
    .stat-item .stat-num   { font-family:var(--font-head); font-weight:800; font-size:1.2rem; color:var(--gold); display:block; }
    .stat-item .stat-label { font-size:0.68rem; color:var(--muted); line-height:1.3; }
    /* ── EARN CARDS ── */
    .earn-card { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); padding:18px; margin-bottom:12px; }
    .earn-card-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
    .earn-badge { font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:3px 9px; border-radius:100px; }
    .badge-hot  { background:rgba(248,113,113,0.15); color:#f87171; border:1px solid rgba(248,113,113,0.3); }
    .badge-free { background:rgba(30,125,79,0.2); color:var(--green2); border:1px solid rgba(36,160,100,0.3); }
    .badge-easy { background:rgba(245,200,66,0.12); color:var(--gold); border:1px solid rgba(245,200,66,0.3); }
    .earn-income { font-family:var(--font-head); font-weight:700; font-size:0.82rem; color:var(--green2); }
    .earn-card h3 { font-family:var(--font-head); font-weight:700; font-size:0.95rem; margin-bottom:6px; }
    .earn-card p  { font-size:0.78rem; color:var(--muted); line-height:1.55; margin-bottom:14px; }
    .earn-actions { display:flex; gap:8px; }
    /* ── STORE / PRODUCT CARDS ── */
    .store-grid   { padding:20px; display:flex; flex-direction:column; gap:14px; }
    .product-card { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
    .product-thumb { width:100%; height:120px; display:flex; align-items:center; justify-content:center; font-size:3rem; }
    .product-thumb.green-grad { background:linear-gradient(135deg,#0f3d25 0%,#1e7d4f 100%); }
    .product-thumb.gold-grad  { background:linear-gradient(135deg,#3d2e00 0%,#8a6a00 100%); }
    .product-thumb.blue-grad  { background:linear-gradient(135deg,#0a1f3d 0%,#1a4080 100%); }
    .product-body { padding:16px; }
    .product-body h3 { font-family:var(--font-head); font-weight:700; font-size:0.95rem; margin-bottom:5px; }
    .product-body p  { font-size:0.78rem; color:var(--muted); line-height:1.5; margin-bottom:14px; }
    .product-footer { display:flex; align-items:center; justify-content:space-between; }
    .price     { font-family:var(--font-head); font-weight:800; font-size:1.1rem; color:var(--gold); }
    .price sub { font-size:0.65rem; color:var(--muted); font-weight:400; margin-left:4px; }
    .product-includes { list-style:none; display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
    .product-includes li { font-size:0.75rem; color:var(--muted); display:flex; align-items:center; gap:7px; }
    .product-includes li::before { content:'✓'; color:var(--green2); font-weight:700; font-size:0.8rem; }
    /* ── DETAILS / ACCORDION ── */
    details { background:var(--black2); border:1px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; margin-bottom:8px; }
    summary { padding:14px 16px; font-size:0.84rem; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:space-between; list-style:none; -webkit-tap-highlight-color:transparent; }
    summary::-webkit-details-marker { display:none; }
    summary::after { content:'+'; color:var(--gold); font-size:1.1rem; font-weight:300; }
    details[open] summary::after { content:'−'; }
    .details-body { padding:0 16px 16px; font-size:0.78rem; color:var(--muted); line-height:1.6; }
    /* ── PAGE HEADER ── */
    .page-header { padding:24px 20px 20px; border-bottom:1px solid var(--border); display:flex; align-items:flex-start; gap:14px; }
    .back-btn { width:36px; height:36px; min-width:36px; background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1rem; text-decoration:none; color:var(--white); -webkit-tap-highlight-color:transparent; }
    .page-header-text h2 { font-family:var(--font-head); font-weight:800; font-size:1.3rem; letter-spacing:-0.02em; margin-bottom:4px; }
    .page-header-text p  { font-size:0.8rem; color:var(--muted); }
    /* ── SPACER + ANIMATIONS ── */
    .bottom-spacer { height:72px; }
    @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.4; transform:scale(0.7); } }
    @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    .animate-in { animation:fadeUp 0.3s ease; }
  </style>
  <style is:global>
    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(14,14,14,0.92);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { font-family: var(--font-head); font-weight: 800; font-size: 1.05rem; letter-spacing: -0.02em; color: var(--white); text-decoration: none; }
    .nav-logo span { color: var(--gold); }
    .nav-flag { font-size: 1.3rem; line-height: 1; }
    .nav-share-btn {
      background: var(--card-bg); border: 1px solid var(--border);
      color: var(--white); width: 36px; height: 36px; border-radius: var(--radius-sm);
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; cursor: pointer;
    }
    .nav-share-btn span { width: 16px; height: 2px; background: var(--white); border-radius: 2px; }

    /* ── BOTTOM NAV ── */
    .bottom-nav {
      position: relative; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 420px;
      background: rgba(14,14,14,0.95);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-top: 1px solid var(--border);
      display: grid; grid-template-columns: repeat(5, 1fr);
      z-index: 100;
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    .bottom-nav a {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 10px 4px; font-size: 0.6rem; color: var(--muted);
      text-decoration: none; gap: 4px; -webkit-tap-highlight-color: transparent; transition: color 0.15s;
    }
    .bottom-nav a .nav-icon { font-size: 1.2rem; line-height: 1; }
    .bottom-nav a.active { color: var(--gold); }
    .bottom-nav a:hover { color: var(--white); }

    /* ── PAYSTACK MODAL ── */
    #paystack-modal {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.8); z-index: 200; align-items: flex-end;
    }
    .modal-sheet {
      background: var(--card-bg); border-radius: 20px 20px 0 0;
      padding: 28px 24px; max-width: 420px; width: 100%; margin: 0 auto;
      border-top: 1px solid var(--border);
    }
    .modal-title  { font-family: var(--font-head); font-weight: 800; font-size: 1.1rem; margin-bottom: 4px; }
    .modal-sub    { color: var(--muted); font-size: 0.8rem; margin-bottom: 20px; }
    .modal-price-box { background: var(--black); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px; margin-bottom: 16px; }
    .modal-price-label { font-size: 0.75rem; color: var(--muted); margin-bottom: 4px; }
    .modal-price-val { font-family: var(--font-head); font-weight: 800; font-size: 1.6rem; color: var(--gold); }
    #modal-email {
      width: 100%; background: var(--black); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 13px 14px; color: var(--white);
      font-size: 0.88rem; margin-bottom: 12px; outline: none; font-family: var(--font-body);
    }
    .modal-note { text-align: center; font-size: 0.7rem; color: var(--muted); margin-top: 12px; }
  </style>
</head>
<body>

  <!-- TOP NAV 
  <nav>
    <a class="nav-logo" href="/">SA <span>Life</span> Hub</a>
    <span class="nav-flag">🇿🇦</span>
    <button class="nav-share-btn" id="nav-share-btn" aria-label="Share this page">
      <span></span><span></span><span></span>
    </button>
  </nav>
   -->
  <!-- PAGE CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <Footer />

  <!-- BOTTOM NAV 
  <nav class="bottom-nav" aria-label="Main navigation">
    <a href="/"       class={activeNav === 'home'  ? 'active' : ''}><span class="nav-icon">🏠</span><span>Home</span></a>
    <a href="/gov"    class={activeNav === 'gov'   ? 'active' : ''}><span class="nav-icon">🏛️</span><span>Gov Help</span></a>
    <a href="/earn"   class={activeNav === 'earn'  ? 'active' : ''}><span class="nav-icon">💰</span><span>Earn</span></a>
    <a href="/store"  class={activeNav === 'store' ? 'active' : ''}><span class="nav-icon">📦</span><span>Store</span></a>
    <a href="/radar"  class={activeNav === 'radar' ? 'active' : ''}><span class="nav-icon">⚠️</span><span>Radar</span></a>
  </nav>
  -->
  

  <!-- PAYSTACK MODAL -->
  <div id="paystack-modal" role="dialog" aria-modal="true" aria-label="Checkout">
    <div class="modal-sheet">
      <div class="modal-title" id="modal-title">Product Name</div>
      <div class="modal-sub">Secure checkout via Paystack 🔒</div>
      <div class="modal-price-box">
        <div class="modal-price-label">Total</div>
        <div class="modal-price-val" id="modal-price">R35</div>
      </div>
      <input id="modal-email" type="email" placeholder="Your email address" autocomplete="email" />
      <button class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:0.9rem;" id="modal-pay-btn">
        💳 Pay with Paystack
      </button>
      <button class="btn btn-outline" style="width:100%;justify-content:center;padding:12px;font-size:0.82rem;margin-top:10px;" id="modal-cancel-btn">
        Cancel
      </button>
      <div class="modal-note">Product delivered to your email within 5 minutes ⚡</div>
    </div>
  </div>

  <script define:vars={{ paystackKey }}>
    // ── PAYSTACK ──────────────────────────────
    const PAYSTACK_KEY = paystackKey;
    let _meta = {};

    window.openPaystack = function(productId, amountKobo, productName) {
      _meta = { productId, amountKobo, productName };
      document.getElementById('modal-title').textContent = productName;
      document.getElementById('modal-price').textContent = 'R' + (amountKobo / 100).toFixed(0);
      const modal = document.getElementById('paystack-modal');
      modal.style.display = 'flex';
    };

    function closePaystack() {
      document.getElementById('paystack-modal').style.display = 'none';
      document.getElementById('modal-email').value = '';
    }

    document.getElementById('modal-cancel-btn').addEventListener('click', closePaystack);
    document.getElementById('paystack-modal').addEventListener('click', function(e) {
      if (e.target === this) closePaystack();
    });

    document.getElementById('modal-pay-btn').addEventListener('click', function() {
      const email = document.getElementById('modal-email').value.trim();
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address to receive your product.');
        return;
      }
      if (typeof PaystackPop !== 'undefined') {
        const handler = PaystackPop.setup({
          key: PAYSTACK_KEY,
          email,
          amount: _meta.amountKobo,
          currency: 'ZAR',
          ref: 'SALHUB_' + Date.now(),
          metadata: { product: _meta.productId },
          callback: function() {
            closePaystack();
            alert('✅ Payment successful! Your product will be sent to ' + email + ' within 5 minutes.');
          },
          onClose: function() {}
        });
        handler.openIframe();
      } else {
        const url = `https://paystack.com/pay/${_meta.productId}?email=${encodeURIComponent(email)}`;
        closePaystack();
        window.open(url, '_blank');
      }
    });

    // Load Paystack SDK
    const ps = document.createElement('script');
    ps.src = 'https://js.paystack.co/v1/inline.js';
    ps.async = true;
    document.head.appendChild(ps);

    // ── WHATSAPP SHARE ─────────────────────────
    const shareMessages = {
      home:             "🇿🇦 *SA Life Hub* — South Africa's #1 digital hub!\n\n✅ SASSA & NSFAS grant updates\n⚠️ Scam Radar — fake news busted\n📊 SARS tax help\n💰 Real ways to earn online\n\nCheck it out 👉 [link]",
      gov:              "🏛️ *SA Life Hub — Government Help*\n\nStep-by-step guides for SASSA, NSFAS, UIF, Smart ID and more!\n\nGet free help 👉 [link]",
      earn:             "💰 *Earn Online in South Africa — Real Verified Opportunities*\n\nNo scams. No upfront fees. Real income from your phone.\n\nSee the full guide 👉 [link]",
