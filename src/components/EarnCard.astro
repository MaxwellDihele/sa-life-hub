---
// src/components/EarnCard.astro
// Usage:
//   <EarnCard
//     badge="hot"
//     badgeLabel="🔥 HOT"
//     income="R300–R1,200/week"
//     title="Sell Digital Products on WhatsApp"
//     category="resell"
//     shareKey="earn-digital"
//     ctaHref="/store"
//     ctaLabel="Get Starter Kit"
//   >
//     <p slot="desc">Description...</p>
//     <ul slot="steps" class="step-list">...</ul>
//   </EarnCard>

export interface Props {
  badge: 'hot' | 'free' | 'easy';
  badgeLabel: string;
  income: string;
  title: string;
  category: string;
  shareKey: string;
  ctaHref?: string;
  ctaLabel?: string;
  ctaExternal?: boolean;
}

const {
  badge,
  badgeLabel,
  income,
  title,
  category,
  shareKey,
  ctaHref,
  ctaLabel = 'Learn More',
  ctaExternal = false,
} = Astro.props;
---

<div class="earn-card earn-item" data-cat={category}>
  <div class="earn-card-top">
    <span class={`earn-badge badge-${badge}`}>{badgeLabel}</span>
    <span class="earn-income">{income}</span>
  </div>
  <h3>{title}</h3>
  <slot name="desc" />
  <slot name="steps" />
  <div class="earn-actions">
    {ctaHref && (
      ctaExternal
        ? <a class="btn btn-green" style="font-size:0.75rem;padding:9px 14px;" href={ctaHref} target="_blank" rel="noopener">{ctaLabel}</a>
        : <a class="btn btn-gold" style="font-size:0.75rem;padding:9px 14px;" href={ctaHref}>{ctaLabel}</a>
    )}
    <button class="btn btn-wa" style="font-size:0.75rem;padding:9px 14px;" data-wa-key={shareKey}>Share</button>
  </div>
</div>
