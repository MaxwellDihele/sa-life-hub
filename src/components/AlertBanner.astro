---
// src/components/AlertBanner.astro
// Usage: <AlertBanner>🔔 <strong>April 2025:</strong> SASSA payment dates confirmed.</AlertBanner>

export interface Props {
  variant?: 'gold' | 'red' | 'green' | 'blue';
}

const { variant = 'gold' } = Astro.props;

const colorMap = {
  gold:  { bg: 'rgba(245,200,66,0.08)',  border: 'rgba(245,200,66,0.25)',  left: 'var(--gold)' },
  red:   { bg: 'rgba(248,113,113,0.08)', border: 'rgba(248,113,113,0.25)', left: '#f87171' },
  green: { bg: 'rgba(36,160,100,0.08)',  border: 'rgba(36,160,100,0.25)',  left: 'var(--green2)' },
  blue:  { bg: 'rgba(96,165,250,0.08)',  border: 'rgba(96,165,250,0.25)',  left: '#60a5fa' },
};

const c = colorMap[variant];
---

<div
  class="alert-banner"
  style={`background:${c.bg};border:1px solid ${c.border};border-left:3px solid ${c.left};`}
>
  <slot />
</div>
