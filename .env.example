# Copy this file to .env and fill in your values
# Never commit .env to git

# ── SUPABASE ──────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
'PUBLIC_SUPABASE_URL=https://euorgiljzmbvoetifsjo.supabase.co'


# Used for the admin panel (server-side only — never exposed to browser)
'SUPABASE_SERVICE_ROLE_KEY='

# ── PAYSTACK ──────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PUBLIC_PAYSTACK_KEY=pk_live_REPLACE_WITH_YOUR_KEY

# ── SITE ──────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://salifehub.co.za

# ── ADMIN PANEL ───────────────────────────────────────────────
# Simple password to protect /admin — change this to something strong
ADMIN_PASSWORD=
